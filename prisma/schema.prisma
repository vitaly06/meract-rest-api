generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  WARNED
  BLOCKED
}

enum ActStatus {
  ONLINE
  OFFLINE
  PLANNED
}

enum ActType {
  SINGLE
  MULTI
}

enum ActFormat {
  SINGLE
  SEVERAL
}

enum SelectionMethods {
  VOTING
  BIDDING
  MANUAL
}

enum TransactionType {
  TRANSFER
  PURCHASE
}

enum TransactionStatus {
  COMPLETED
  FAILED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum IconPackType {
  ACHIEVEMENT
  RANK
}

model ActRating {
  id     Int   @id @default(autoincrement())
  value  Float // 0..10, step 0.5

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  actId Int
  act   Act  @relation(fields: [actId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, actId])
  @@index([actId])
}

model Ticket {
  id          Int             @id @default(autoincrement())
  title       String
  description String          @db.Text
  img         String?         @db.Text
  status      TicketStatus    @default(OPEN)
  userId      Int
  user        User            @relation(fields: [userId], references: [id])
  
  messages    TicketMessage[]
  
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model TicketMessage {
  id        Int      @id @default(autoincrement())
  text      String   @db.Text
  
  ticketId  Int
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  
  createdAt DateTime @default(now())
}



model User {
  id             Int        @id @default(autoincrement())
  login          String?    @unique
  fullName String?
  password       String
  phoneNumber String?
  email          String     @unique
  refreshToken             String?
  avatarUrl String?
  timeZone String?
  communicationLanguages String[] @default([])
  country String?
  city    String?

  balance Float @default(0)

  tickets Ticket[] 
  ticketMessages TicketMessage[]

  // Notification settings
  notifyAll             Boolean @default(true)
  notifyActProgress     Boolean @default(true)
  notifyGuildInvites    Boolean @default(true)
  notifyChatMentions    Boolean @default(true)
  notifyActStatusRealtime Boolean @default(true)

  points Int @default(0)

  // Security
  twoFactorSecret  String?
  twoFactorEnabled Boolean @default(false)

  // Privacy
  whoCanMessage String @default("all") // all | act_participants | guild_members

  status         UserStatus @default(ACTIVE)
  warningCount   Int        @default(0)
  roleId         Int        @default(1)
  role           Role       @relation(fields: [roleId], references: [id])
  terminateCount Int?

  following User[] @relation("UserFollows")
  followers User[] @relation("UserFollows")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  intros                   Intro[]
  outros                   Outro[]
  musics                   Music[]
  effects                  Effect[]
  Act                      Act[]
  sequels                  Sequel[]
  UserActivity             UserActivity[]
  UserActivityParticipants UserActivityParticipants[]
  ChatMessage              ChatMessage[]
  GuildChatMessage         GuildChatMessage[]
  achievements             UserAchievement[]
  ranks                    UserRank[]
  Guild                    Guild?                     @relation(fields: [guildId], references: [id])
  guildId                  Int?
  guildJoinRequests        GuildJoinRequest[]

  ActSpotAgent          ActSpotAgent[]
  ActSpotAgentCandidate ActSpotAgentCandidate[]
  ActSpotAgentVote      ActSpotAgentVote[]

  ActParticipants   ActParticipant[]   @relation("UserActParticipants")
  RoleCandidates    RoleCandidate[]    @relation("UserRoleCandidates")
  RoleVotes         RoleVote[]         @relation("UserRoleVotes")
  ActTeamCandidates ActTeamCandidate[]
  ActTeamCandidateVotes ActTeamCandidateVote[]

  chatMembers ChatMember[]
  messages    Message[]   @relation("MessageSender")

  pollsCreated Poll[]     @relation("PollCreator")
  pollVotes    PollVote[] @relation("PollVotes")

  notifications Notification[]

  lastSeenAt DateTime?

  transactions              Transaction[] @relation("UserTransactions")
  transactionsAsCounterpart Transaction[] @relation("TransactionCounterpart")
  stripePayments            StripePayment[]
  actRatings                ActRating[]
  guildNotificationMutes    GuildNotificationMute[]
  adminTasksCreated         AdminTask[]   @relation("AdminTaskCreator")
  adminTasksAssigned        AdminTask[]   @relation("AdminTaskAssignee")
  policiesUpdated           Policy[]      @relation("PolicyUpdatedBy")
  consentsUpdated           Consent[]     @relation("ConsentUpdatedBy")
}

model Role {
  id   Int    @id @default(autoincrement())
  name String @unique
  User User[]
}

model Guild {
  id           Int     @id @default(autoincrement())
  name         String  @unique
  description  String?
  logoFileName String?
  coverFileName String?
  tags         String[] @default([])

  ownerId Int

  members      User[]
  messages     GuildChatMessage[]
  joinRequests GuildJoinRequest[]
  chat         Chat?
  achievements GuildAchievement[]
  notificationMutes GuildNotificationMute[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GuildJoinRequest {
  id      Int   @id @default(autoincrement())
  guildId Int
  guild   Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  userId  Int
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  status    String   @default("pending") // pending | approved | rejected
  message   String?  // сообщение от пользователя
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([guildId, userId])
}

model GuildNotificationMute {
  id      Int   @id @default(autoincrement())
  userId  Int
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  guildId Int
  guild   Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, guildId])
  @@index([userId])
}

model Act {
  id              Int     @id @default(autoincrement())
  title           String
  description     String?
  previewFileName String?
  sequelId        Int?
  sequel          Sequel?  @relation(fields: [sequelId], references: [id], onDelete: Cascade)

  chapterId       Int?
  chapter         Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  scheduledAt     DateTime?  // planned date for PLANNED acts

  type             ActType          @default(SINGLE)
  format           ActFormat        @default(SINGLE)
  heroMethods      SelectionMethods @default(VOTING)
  navigatorMethods SelectionMethods @default(VOTING)
  spotAgentMethods SelectionMethods @default(VOTING)
  spotAgentCount   Int              @default(0)
  biddingTime      DateTime?

  tags String[] @default([])

  introId Int?
  intro   Intro? @relation(fields: [introId], references: [id], onDelete: Cascade)

  outroId Int?
  outro   Outro? @relation(fields: [outroId], references: [id], onDelete: Cascade)

  effectId Int?
  effect   Effect? @relation(fields: [effectId], references: [id], onDelete: Cascade)

  musics ActMusic[]

  status    ActStatus @default(ONLINE)
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  likes     Int       @default(0)

  // Agora Cloud Recording
  recordingResourceId String?
  recordingSid        String?
  recordingUrl        String?
  recordingStatus     String?

  // Location
  startLatitude        Float?
  startLongitude       Float?
  destinationLatitude  Float?
  destinationLongitude Float?

  // Act Category
  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  UserActivity        UserActivity[]
  ChatMessage         ChatMessage[]
  tasks               ActTask[]
  routePoints         RoutePoint[]
  spotAgents          ActSpotAgent[]
  spotAgentCandidates ActSpotAgentCandidate[]

  participants        ActParticipant[]
  heroCandidates      RoleCandidate[]  @relation("HeroCandidates")
  navigatorCandidates RoleCandidate[]  @relation("NavigatorCandidates")
  RoleCandidate       RoleCandidate[]

  // Teams
  teams ActTeam[]

  polls Poll[]
  chats Chat[]
  ratings ActRating[]
}

model ActParticipant {
  id     Int  @id @default(autoincrement())
  actId  Int
  act    Act  @relation(fields: [actId], references: [id], onDelete: Cascade)
  userId Int
  user   User @relation("UserActParticipants", fields: [userId], references: [id], onDelete: Cascade)

  role     String // "hero" | "navigator" | "initiator" | "spot_agent" | "viewer"
  status   String    @default("applied") // applied → approved → onboard → active → completed/dropped
  joinedAt DateTime?
  leftAt   DateTime?

  @@unique([actId, userId, role])
  @@index([actId, role])
}

model RoleCandidate {
  id     Int  @id @default(autoincrement())
  actId  Int
  act    Act  @relation(fields: [actId], references: [id], onDelete: Cascade)
  userId Int
  user   User @relation("UserRoleCandidates", fields: [userId], references: [id], onDelete: Cascade)

  roleType  String // "hero" | "navigator"
  method    SelectionMethods
  bidAmount Float? // для BIDDING
  bidItem   String? // текстовое обещание / артефакт
  appliedAt DateTime         @default(now())
  status    String           @default("pending") // pending → approved → rejected

  // Обратные связи к Act (для heroCandidates и navigatorCandidates)
  heroAct        Act? @relation("HeroCandidates", fields: [heroActId], references: [id])
  heroActId      Int?
  navigatorAct   Act? @relation("NavigatorCandidates", fields: [navigatorActId], references: [id])
  navigatorActId Int?

  votes RoleVote[]

  @@unique([actId, userId, roleType])
  @@index([actId, roleType])
}

model RoleVote {
  id          Int           @id @default(autoincrement())
  candidateId Int
  candidate   RoleCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  voterId     Int
  voter       User          @relation("UserRoleVotes", fields: [voterId], references: [id], onDelete: Cascade)
  votedAt     DateTime      @default(now())

  @@unique([candidateId, voterId])
}

// Точки маршрута для стрима
model RoutePoint {
  id        Int      @id @default(autoincrement())
  actId     Int
  act       Act      @relation(fields: [actId], references: [id], onDelete: Cascade)
  latitude  Float
  longitude Float
  order     Int // Порядок точки в маршруте (0, 1, 2, ...)
  createdAt DateTime @default(now())

  @@index([actId, order])
}

// Stream Categories
model Category {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String? @db.Text
  order       Int     @default(0)
  isActive    Boolean @default(true)
  Act         Act[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sequel {
  id            Int       @id @default(autoincrement())
  title         String
  episodes      Int
  coverFileName String?
  userId        Int
  acts          Act[]
  chapters      Chapter[]
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Chapter {
  id       Int    @id @default(autoincrement())
  title    String
  order    Int    @default(0)

  sequelId Int
  sequel   Sequel @relation(fields: [sequelId], references: [id], onDelete: Cascade)

  acts Act[]

  createdAt DateTime @default(now())

  @@index([sequelId])
}

model Intro {
  id       Int    @id @default(autoincrement())
  fileName String
  acts     Act[]
  userId   Int?
  user     User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Outro {
  id       Int    @id @default(autoincrement())
  fileName String
  acts     Act[]
  userId   Int?
  user     User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Music {
  id       Int        @id @default(autoincrement())
  fileName String
  length   String
  acts     ActMusic[]
  userId   Int?
  user     User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Effect {
  id       Int    @id @default(autoincrement())
  fileName String
  acts     Act[]
  userId   Int?
  user     User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActMusic {
  act   Act @relation(fields: [actId], references: [id], onDelete: Cascade)
  actId Int

  music   Music @relation(fields: [musicId], references: [id], onDelete: Cascade)
  musicId Int

  order Int @default(0) // Порядок воспроизведения музыки

  @@id([actId, musicId])
  @@index([actId])
}

model UserActivity {
  id        Int      @id @default(autoincrement())
  action    String
  details   Json?
  createdAt DateTime @default(now())

  participants UserActivityParticipants[]
  User         User?                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       Int?
  Act          Act?                       @relation(fields: [streamId], references: [id])
  streamId     Int?
}

model UserActivityParticipants {
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  activity   UserActivity @relation(fields: [activityId], references: [id])
  activityId Int

  role String?

  @@id([userId, activityId])
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  message   String
  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  actId Int
  act   Act @relation(fields: [actId], references: [id], onDelete: Cascade)

  @@index([actId, createdAt])
}

model Achievement {
  id   Int    @id @default(autoincrement())
  name String @unique
  imageUrl String?

  users  UserAchievement[]
  guilds GuildAchievement[]

  createdAt DateTime @default(now())
}

model Rank {
  id       Int    @id @default(autoincrement())
  name     String @unique
  imageUrl String?

  users UserRank[]

  createdAt DateTime @default(now())
}

model UserAchievement {
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  achievementId Int

  isBest    Boolean  @default(false)
  awardedAt DateTime @default(now())

  @@id([userId, achievementId])
  @@index([userId])
}

model GuildAchievement {
  guild   Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId Int

  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  achievementId Int

  awardedAt DateTime @default(now())
  order     Int      @default(0)
  featured  Boolean  @default(false)

  @@id([guildId, achievementId])
  @@index([guildId])
}

model UserRank {
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  rank   Rank @relation(fields: [rankId], references: [id], onDelete: Cascade)
  rankId Int

  @@id([userId, rankId])
  @@index([userId])
}

// ============================================
// ICON PACKS
// ============================================

model IconPack {
  id        Int            @id @default(autoincrement())
  name      String
  type      IconPackType
  isActive  Boolean        @default(false)
  icons     IconPackItem[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([type, isActive])
}

model IconPackItem {
  id        Int      @id @default(autoincrement())
  name      String
  url       String
  s3Key     String
  pack      IconPack @relation(fields: [packId], references: [id], onDelete: Cascade)
  packId    Int
  createdAt DateTime @default(now())

  @@index([packId])
}

// Диапазоны расстояний для ползунка локации (задаётся в админке)
model LocationRange {
  id        Int      @id @default(autoincrement())
  label     String   // "Город", "Область", "Страна" и т.д.
  minKm     Float    // нижняя граница диапазона (км)
  maxKm     Float    // верхняя граница диапазона (км)
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order, isActive])
}

model GuildChatMessage {
  id        Int      @id @default(autoincrement())
  message   String
  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  guildId Int
  guild   Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, createdAt])
}

model ActTask {
  id          Int       @id @default(autoincrement())
  title       String
  isCompleted Boolean   @default(false)
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  actId Int
  act   Act @relation(fields: [actId], references: [id], onDelete: Cascade)

  @@index([actId])
}

model ActSpotAgent {
  id    Int @id @default(autoincrement())
  actId Int
  act   Act @relation(fields: [actId], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  task   String?
  status String  @default("pending") // pending, active, completed

  assignedAt  DateTime  @default(now())
  completedAt DateTime?

  @@unique([actId, userId])
  @@index([actId])
  @@index([userId])
}

model ActSpotAgentCandidate {
  id    Int @id @default(autoincrement())
  actId Int
  act   Act @relation(fields: [actId], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  status    String   @default("pending") // pending, approved, rejected
  appliedAt DateTime @default(now())

  votes ActSpotAgentVote[]

  @@unique([actId, userId])
  @@index([actId])
  @@index([userId])
}

model ActSpotAgentVote {
  id          Int                   @id @default(autoincrement())
  candidateId Int
  candidate   ActSpotAgentCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  voterId Int
  voter   User @relation(fields: [voterId], references: [id], onDelete: Cascade)

  votedAt DateTime @default(now())

  @@unique([candidateId, voterId])
  @@index([candidateId])
  @@index([voterId])
}

// ─── Act Teams (new structure) ────────────────────────────────────────────────

model ActTeam {
  id    Int    @id @default(autoincrement())
  actId Int
  act   Act    @relation(fields: [actId], references: [id], onDelete: Cascade)
  name  String

  roleConfigs ActTeamRoleConfig[]
  tasks       ActTeamTask[]

  createdAt DateTime @default(now())

  @@index([actId])
}

// Per-role config: either specific candidates OR open voting
model ActTeamRoleConfig {
  id     Int     @id @default(autoincrement())
  teamId Int
  team   ActTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  role String // "hero" | "navigator" | "spot_agent"

  openVoting          Boolean   @default(false)
  votingStartAt       DateTime?
  votingDurationHours Int?

  candidates ActTeamCandidate[]

  @@unique([teamId, role])
}

model ActTeamCandidate {
  id       Int               @id @default(autoincrement())
  configId Int
  config   ActTeamRoleConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  userId   Int
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes    ActTeamCandidateVote[]

  @@unique([configId, userId])
}

model ActTeamCandidateVote {
  id          Int              @id @default(autoincrement())
  candidateId Int
  candidate   ActTeamCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  voterId     Int
  voter       User             @relation(fields: [voterId], references: [id], onDelete: Cascade)
  votedAt     DateTime         @default(now())

  @@unique([candidateId, voterId])
  @@index([candidateId])
}

model ActTeamTask {
  id          Int     @id @default(autoincrement())
  teamId      Int
  team        ActTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  imageUrl    String?
  description String
  address     String?
  order       Int     @default(0)

  createdAt DateTime @default(now())

  @@index([teamId])
}

// ─── Chat System ──────────────────────────────────────────────────────────────

model Chat {
  id         Int     @id @default(autoincrement())
  type       String  @default("direct") // direct | group | guild
  name       String? // for group/guild chats
  imageUrl   String? // cover image for group chats (S3 url)
  inviteCode String? @unique // random token for invite links (group/guild only)

  // For guild chats — one-to-one with Guild
  guildId Int?   @unique
  guild   Guild? @relation(fields: [guildId], references: [id], onDelete: Cascade)

  // For act stream group chats
  actId Int?
  act   Act?  @relation(fields: [actId], references: [id], onDelete: SetNull)

  // Creator of the chat (for group chats)
  creatorId Int?

  members  ChatMember[]
  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatMember {
  id     Int  @id @default(autoincrement())
  chatId Int
  chat   Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  lastReadAt DateTime?
  isMuted    Boolean   @default(false)
  joinedAt   DateTime  @default(now())

  @@unique([chatId, userId])
  @@index([userId])
}

// ─── Poll System ─────────────────────────────────────────────────────────────

model Poll {
  id          Int      @id @default(autoincrement())
  actId       Int
  act         Act      @relation(fields: [actId], references: [id], onDelete: Cascade)
  creatorId   Int
  creator     User     @relation("PollCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  title       String
  description String?
  endsAt      DateTime
  isActive    Boolean  @default(true)

  options PollOption[]
  votes   PollVote[]

  createdAt DateTime @default(now())

  @@index([actId])
}

model PollOption {
  id     Int        @id @default(autoincrement())
  pollId Int
  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  text   String
  votes  PollVote[]

  @@index([pollId])
}

model PollVote {
  id       Int        @id @default(autoincrement())
  pollId   Int
  poll     Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionId Int
  option   PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  userId   Int
  user     User       @relation("PollVotes", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([pollId, userId])
  @@index([pollId])
}

model Message {
  id       Int  @id @default(autoincrement())
  chatId   Int
  chat     Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId Int
  sender   User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  text     String? // text content (optional if file sent)
  fileUrl  String? // S3 url for uploaded file / voice
  fileType String? // image | video | audio | voice | file

  // Reply to a specific message
  replyToId Int?
  replyTo   Message?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Message[] @relation("MessageReplies")

  // Forwarded from another message
  forwardedFromId Int?
  forwardedFrom   Message?  @relation("MessageForwards", fields: [forwardedFromId], references: [id], onDelete: SetNull)
  forwards        Message[] @relation("MessageForwards")

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([chatId, createdAt])
  @@index([senderId])
}

// ─── Notification System ─────────────────────────────────────────────────────

model Notification {
  id      Int  @id @default(autoincrement())
  userId  Int
  user    User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // new_message | guild_join_request | guild_join_approved | guild_join_rejected
  // role_assigned | achievement_awarded | guild_invite
  type    String

  title   String
  body    String
  imageUrl String? // avatar or chat/guild image

  // Extra context passed to frontend (chatId, actId, guildId, senderId, role, etc.)
  metadata Json?

  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, isRead])
}

model Transaction {
  id     Int               @id @default(autoincrement())
  type   TransactionType
  status TransactionStatus @default(COMPLETED)
  // signed: positive = funds received, negative = funds sent
  amount Int

  userId Int
  user   User @relation("UserTransactions", fields: [userId], references: [id], onDelete: Cascade)

  // the other party in a TRANSFER (null for PURCHASE)
  counterpartId Int?
  counterpart   User? @relation("TransactionCounterpart", fields: [counterpartId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
}

model ShopProduct {
  id       Int     @id @default(autoincrement())
  price    Float
  currency Float
  imageUrl String?
  oldPrice Float?
  discount Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  payments StripePayment[]
}

model StripePayment {
  id              Int         @id @default(autoincrement())
  userId          Int
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId       Int
  product         ShopProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  paymentIntentId String      @unique
  amount          Int         // cents
  currency        String      @default("usd")
  status          String      @default("pending") // pending | succeeded | failed
  echoAwarded     Int         // кол-во echo начислено
  createdAt       DateTime    @default(now())

  @@index([userId])
  @@index([paymentIntentId])
}

// Singleton: главное видео на главной странице (только одна запись)
model HeroVideo {
  id        Int      @id @default(autoincrement())
  url       String   // S3 URL
  s3Key     String   // ключ файла в S3 для удаления
  mimeType  String   @default("video/mp4")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Задачи от главного админа — назначаются конкретному admin
model AdminTask {
  id          Int       @id @default(autoincrement())
  title       String
  description String?   @db.Text
  deadline    DateTime?
  isDone      Boolean   @default(false)
  doneAt      DateTime?

  // Кто создал (main admin)
  creatorId Int
  creator   User @relation("AdminTaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  // Кому назначена задача (admin)
  assigneeId Int
  assignee   User @relation("AdminTaskAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assigneeId])
  @@index([creatorId])
}

// Политики (privacy policy, terms of service и др.)
model Policy {
  id          Int      @id @default(autoincrement())
  slug        String   @unique // e.g. "privacy-policy", "terms-of-service"
  title       String
  content     String   @db.Text
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedById Int?
  updatedBy   User?    @relation("PolicyUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([slug])
}

// Согласия пользователей (cookies, маркетинг и др.)
model Consent {
  id          Int      @id @default(autoincrement())
  slug        String   @unique // e.g. "cookies", "marketing-emails"
  title       String
  description String?  @db.Text
  isRequired  Boolean  @default(false)
  version     String   @default("1.0")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedById Int?
  updatedBy   User?    @relation("ConsentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([slug])
}
